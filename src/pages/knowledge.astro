---
import { KnowledgeGraph } from "@/components/knowledge";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Knowledge Graph" description="Scrapboxに蓄積した知識の構造と接続を可視化">
  <div class="container mx-auto px-4 py-8 max-w-6xl">
    <div class="mb-8">
      <h1 class="text-2xl font-bold mb-2">Knowledge Graph</h1>
      <p class="text-muted-foreground">
        Scrapboxに蓄積した知識の構造と接続を可視化しています。
      </p>
    </div>
    <KnowledgeGraph client:load />
  </div>
</BaseLayout>
