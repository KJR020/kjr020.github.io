---
import { getCollection, render } from "astro:content";
import ImageLightbox from "@/components/article/ImageLightbox.astro";
import { Comments } from "@/components/Comments";
import PostMeta from "@/components/PostMeta.astro";
import type { HeadingItem } from "@/components/toc";
import { TableOfContents } from "@/components/toc";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { createPublishedPostStaticPaths } from "@/lib/postRoutes";
import "@/styles/article-code.css";
import "@/styles/article-content.css";
import "@/styles/article-footnotes.css";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return createPublishedPostStaticPaths(posts);
}

const { post } = Astro.props;
const { Content, headings: rawHeadings } = await render(post);

// h2, h3のみを抽出して型変換
const headings: HeadingItem[] = rawHeadings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => ({
    id: h.slug,
    text: h.text,
    level: h.depth as 2 | 3,
  }));

// Giscus configuration from environment variables
const giscusRepo = import.meta.env.PUBLIC_GISCUS_REPO as `${string}/${string}`;
const giscusRepoId = import.meta.env.PUBLIC_GISCUS_REPO_ID;
const giscusCategory = import.meta.env.PUBLIC_GISCUS_CATEGORY;
const giscusCategoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID;
---

<BaseLayout
  title={`${post.data.title} - KJR020's Blog`}
  description={post.data.description}
  ogType="article"
  articleHeadline={post.data.title}
  articlePublishedTime={post.data.date}
  articleTags={post.data.tags}
>
  <div class="post-page container mx-auto px-4 py-phi-2xl max-w-6xl">
    <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_250px] lg:gap-phi-2xl">
      {/* 記事本文 */}
      <article class="min-w-0">
        <header class="mb-phi-2xl">
          <h1 class="font-bold font-heading tracking-tight mb-phi-md" style="font-size: var(--font-size-title1); line-height: var(--lh-tight);">{post.data.title}</h1>
          <PostMeta date={post.data.date} tags={post.data.tags} />
        </header>

        <div class="prose prose-neutral dark:prose-invert max-w-none article-reading-content">
          <Content />
        </div>

        <ImageLightbox />

        <Comments
          repo={giscusRepo}
          repoId={giscusRepoId}
          category={giscusCategory}
          categoryId={giscusCategoryId}
          client:only="react"
        />
      </article>

      {/* デスクトップ用目次（右側サイドバー） */}
      <aside class="hidden lg:block">
        <TableOfContents
          headings={headings}
          avatarSrc="/images/kuri_photo.png"
          avatarAlt="KJR020"
          client:load
        />
      </aside>
    </div>
  </div>
</BaseLayout>

<script>
  import { enhanceArticleCodeBlocks } from "@/lib/articleCode";
  import { enhanceFootnotes } from "@/lib/footnotes";

  function initializePostContent() {
    const article = document.querySelector(".article-reading-content");
    if (article) enhanceArticleCodeBlocks(article);
    enhanceFootnotes();
  }

  // DOMContentLoadedで確実に実行
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializePostContent);
  } else {
    initializePostContent();
  }
  // View Transitions対応
  document.addEventListener('astro:page-load', initializePostContent);
</script>

<style is:global>
  .prose {
    --tw-prose-body: var(--foreground);
    --tw-prose-headings: var(--foreground);
    --tw-prose-links: var(--link);
    --tw-prose-bold: var(--foreground);
    --tw-prose-code: var(--foreground);
  }

  .prose h2 {
    margin-top: 2.618rem; /* φ² */
    margin-bottom: 1rem;
    font-size: var(--font-size-title2); /* φ = 1.618rem */
    line-height: var(--lh-tight); /* √φ = 1.272 */
    font-weight: 700;
    font-family: var(--font-heading);
    letter-spacing: -0.01em;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.618rem; /* 1/φ */
  }

  .prose h3 {
    margin-top: 1.618rem; /* φ */
    margin-bottom: 0.618rem; /* 1/φ */
    font-size: var(--font-size-title3); /* √φ = 1.272rem */
    line-height: var(--lh-tight); /* √φ = 1.272 */
    font-weight: 500;
    font-family: var(--font-heading);
    letter-spacing: -0.005em;
  }

  .prose p {
    margin-top: 1rem;
    margin-bottom: 1rem;
    line-height: var(--lh-body); /* φ = 1.618 */
  }

  .prose ul,
  .prose ol {
    margin-top: 1rem;
    margin-bottom: 1rem;
    padding-left: 1.618rem; /* φ */
  }

  /* リストマーカースタイル */
  .prose ul {
    list-style-type: disc;
  }

  .prose ol {
    list-style-type: decimal;
  }

  /* ネストリストの階層別マーカー */
  .prose ul ul {
    list-style-type: circle;
  }

  .prose ul ul ul {
    list-style-type: square;
  }

  .prose li {
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
  }

  /* インラインコード */
  .prose :not(pre) > code {
    background-color: var(--muted);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    font-family: var(--font-mono);
  }

  .prose a {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 150ms;
  }

  .prose a:hover {
    color: var(--link-hover);
  }

  .prose img {
    max-width: 100%;
    height: auto;
    width: auto;
  }

  .prose blockquote {
    border-left: 4px solid var(--border);
    padding-left: 1rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
    font-style: italic;
    color: var(--muted-foreground);
  }

  /* 表スタイル */
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
    margin-bottom: 1rem;
    display: block;
    overflow-x: auto;
  }

  .prose th,
  .prose td {
    border: 1px solid var(--border);
    padding: 0.382rem 0.618rem; /* φ⁻² × φ⁻¹ */
    text-align: left;
  }

  .prose th {
    background-color: var(--muted);
    font-weight: 600;
  }

  .prose tbody tr:nth-child(even) {
    background-color: color-mix(in srgb, var(--muted) 50%, transparent);
  }
</style>
