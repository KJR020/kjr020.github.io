---
import { Badge } from "@/components/ui/badge";

interface Props {
  date: Date;
  tags?: string[];
}

const { date, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground min-h-7">
  <time datetime={date.toISOString()}>
    {formattedDate}
  </time>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1">
      {tags.map((tag) => (
        <a
          href={`/tags/${tag}`}
          class="post-tag-link relative z-10 inline-flex rounded-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link focus-visible:ring-offset-2 focus-visible:ring-offset-background"
        >
          <Badge variant="secondary" className="post-tag-label cursor-pointer">
            {tag}
          </Badge>
        </a>
      ))}
    </div>
  )}
</div>

<style>
  .post-tag-link {
    overflow: hidden;
    isolation: isolate;
    background: var(--secondary);
  }

  .post-tag-link::before {
    position: absolute;
    inset-block: 0;
    inset-inline-start: -15%;
    z-index: 0;
    inline-size: 130%;
    background: var(--foreground);
    content: "";
    opacity: 0.06;
    pointer-events: none;
    transform: translate3d(-105%, 0, 0) skew(14deg);
    transition: transform 220ms ease-in-out;
  }

  .post-tag-link:is(:hover, :focus-visible)::before {
    transform: translate3d(0, 0, 0) skew(14deg);
  }

  .post-tag-link :global(.post-tag-label) {
    position: relative;
    z-index: 1;
    background: transparent;
    transition: color 200ms ease-out;
  }

  .post-tag-link:is(:hover, :focus-visible) :global(.post-tag-label) {
    color: var(--link);
  }

  @media (prefers-reduced-motion: reduce) {
    .post-tag-link::before {
      transition-duration: 0s;
    }
  }
</style>
