---
import { getCollection } from "astro:content";

import PageHero from "@/components/PageHero.astro";
import PostCard from "@/components/PostCard.astro";
import PostMeta from "@/components/PostMeta.astro";
import { ThemeToggleAnimated } from "@/components/theme/ThemeToggleAnimated";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import {
  Card,
  CardAction,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import BaseHead from "@/layouts/BaseHead.astro";
import "@/styles/globals.css";
import "../styles.css";

const colorTokens = [
  { name: "--background", label: "Background / Card", role: "ページと面" },
  { name: "--foreground", label: "Foreground", role: "本文と主要情報" },
  { name: "--primary", label: "Primary", role: "主要操作" },
  { name: "--link", label: "Link", role: "遷移可能な情報" },
  { name: "--secondary", label: "Secondary / Muted", role: "補助操作と弱い面" },
  { name: "--muted-foreground", label: "Muted foreground", role: "補助情報" },
  { name: "--border", label: "Border / Input", role: "領域の境界" },
  { name: "--destructive", label: "Destructive", role: "破壊的な操作とエラー" },
] as const;

const typeScale = [
  ["Display", "--font-size-display", "700", "404など単一状態の強調"],
  ["Title 1", "--font-size-title1", "700", "ページタイトル・記事タイトル"],
  ["Title 2", "--font-size-title2", "700", "セクション見出し"],
  ["Title 3", "--font-size-title3", "500", "小見出し"],
  ["Body", "--font-size-body", "400", "本文"],
  ["Small", "--font-size-small", "400", "補助テキスト・メタ情報"],
  ["Caption", "--font-size-caption", "400", "短い補足"],
] as const;

const spacingTokens = [
  ["φ⁻³", "--phi-neg3"],
  ["φ⁻²", "--phi-neg2"],
  ["φ⁻¹", "--phi-neg1"],
  ["φ⁰", "--phi-0"],
  ["φ¹", "--phi-1"],
  ["φ²", "--phi-2"],
  ["φ³", "--phi-3"],
] as const;

const posts = await getCollection("posts", ({ data }) => !data.draft);
const specimenPost = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0] ?? {
  id: "design-system-specimen",
  data: {
    title: "Living Design Systemをブログと育てる",
    date: new Date("2026-07-16"),
    tags: ["Design System", "Astro"],
  },
};

const buttonCode = `<Button variant="default">記事を読む</Button>
<Button variant="outline">下書きを確認</Button>
<Button variant="destructive">削除する</Button>`;
---

<!doctype html>
<html lang="ja" class="scroll-smooth">
  <head>
    <BaseHead
      title="KJR020ブログ デザインシステム見本帳"
      description="KJR020ブログの実装と接続されたLiving Design System"
    />
    <meta name="robots" content="noindex,nofollow" />
  </head>
  <body data-layout="specimen-book" class="bg-background text-foreground antialiased">
    <header class="book-header">
      <div class="book-header-inner">
        <a href="/design-system" class="brand" aria-label="デザインシステム見本帳の先頭へ">
          <img src="/images/kuri_photo.png" alt="" width="32" height="32" />
          <span class="brand-copy">
            <strong>KJR020's Blog</strong>
            <small>Living Design System · 開発環境限定</small>
          </span>
        </a>
        <div class="header-actions">
          <Badge variant="outline">DEV ONLY</Badge>
          <a href="/" class="blog-link">ブログを見る</a>
          <ThemeToggleAnimated client:load />
        </div>
      </div>
    </header>

    <main class="book">
      <header class="book-intro" id="overview">
        <h1 class="book-title">KJR020ブログ<br />デザインシステム見本帳</h1>
        <p class="book-lead">
          KJR020ブログの視覚言語、UI部品、ページパターン、UIライティングを確認する正規仕様。
          標本はブログと同じトークンとコンポーネントから描画する。
        </p>
        <div class="scope-note">
          <strong>適用範囲</strong>
          <span>
            ブログのすべてのページと部品に適用する。このページは開発サーバーでのみ表示し、本番ビルドには含めない。
          </span>
        </div>
      </header>

      <nav class="toc" aria-label="章目次">
        <a href="#foundations">1. Foundations</a>
        <a href="#components">2. Components</a>
        <a href="#patterns">3. Blog patterns</a>
        <a href="#writing">4. UI writing</a>
        <a href="#accessibility">5. Accessibility</a>
        <a href="#governance">6. Governance</a>
      </nav>

      <section class="spec" id="foundations">
        <h2>1. Foundations</h2>

        <div class="spec-item" id="color">
          <h3>1-1. 色の役割</h3>
          <p class="src">
            ライト/ダークの2テーマ。色名ではなく用途を表すsemantic tokenを選ぶ。表示値は
            <code>globals.css</code>から取得する。
          </p>
          <div class="demo swatches">
            {colorTokens.map((token) => (
              <div class="swatch" data-token={token.name}>
                <div class="swatch-color" style={`--swatch: var(${token.name})`}></div>
                <strong>{token.label}</strong>
                <code data-token-value={token.name}>var({token.name})</code>
                <span>{token.role}</span>
              </div>
            ))}
          </div>
          <p class="source-row"><strong>Source</strong><code>src/styles/globals.css</code></p>
        </div>

        <div class="spec-item" id="typography">
          <h3>1-2. 文字階層</h3>
          <p class="src">
            日本語とUIはNoto Sans JP、コードとトークン名はJetBrains Monoを使用する。サイズと行高は黄金比φを中心に組む。
          </p>
          <div class="demo type-list">
            {typeScale.map(([label, token, weight, usage]) => (
              <div class="type-row">
                <div style={`font-size: var(${token}); font-weight: ${weight}`}>読みやすさから設計する</div>
                <dl>
                  <div><dt>{label}</dt><dd><code>{token}</code></dd></div>
                  <div><dt>用途</dt><dd>{usage}</dd></div>
                </dl>
              </div>
            ))}
          </div>
          <p class="source-row"><strong>Source</strong><code>src/styles/globals.css</code><code>src/layouts/BaseHead.astro</code></p>
        </div>

        <div class="spec-item" id="spacing">
          <h3>1-3. 黄金比スペーシング</h3>
          <p class="src">関連性が強い要素には狭い値を使い、セクションなど関係が切り替わる場所には広い値を使う。</p>
          <div class="demo spacing-list">
            {spacingTokens.map(([label, token]) => (
              <div class="spacing-row">
                <code>{label}</code>
                <span class="spacing-bar" style={`--space: var(${token})`}></span>
                <code>{token}</code>
                <span data-token-value={token}>var({token})</span>
              </div>
            ))}
          </div>
          <p class="source-row"><strong>Source</strong><code>src/styles/globals.css</code></p>
        </div>

        <div class="spec-item" id="grid">
          <h3>1-4. Grid</h3>
          <p class="src">
            ページ骨格はCompact 2列、Medium 6列、Wide 12列。部品内部の配置にはGridではなくspacing tokenを使う。
          </p>
          <div class="demo">
            <div class="grid-anatomy" aria-label="12列グリッドの見本">
              {Array.from({ length: 12 }).map((_, index) => <span>{index + 1}</span>)}
            </div>
            <table class="map grid-table">
              <thead><tr><th>Mode</th><th>Viewport</th><th>Columns</th><th>Gutter</th><th>Margin</th></tr></thead>
              <tbody>
                <tr><td>Compact</td><td>320–767px</td><td>2</td><td>12px</td><td>16px</td></tr>
                <tr><td>Medium</td><td>768–1023px</td><td>6</td><td>12px</td><td>16px</td></tr>
                <tr><td>Wide</td><td>1024px以上</td><td>12</td><td>16px</td><td>32px</td></tr>
              </tbody>
            </table>
          </div>
          <p class="source-row"><strong>Specification</strong><code>docs/grid-system.md</code></p>
        </div>

        <div class="spec-item" id="radius">
          <h3>1-5. 角丸</h3>
          <p class="src">基準値は0.618rem。情報のまとまりを示す目的で使用し、装飾として過剰に丸めない。</p>
          <div class="demo radius-grid">
            <div><span class="radius-sample radius-sm"></span><strong>Small</strong><code>--radius-sm</code></div>
            <div><span class="radius-sample radius-md"></span><strong>Medium</strong><code>--radius-md</code></div>
            <div><span class="radius-sample radius-lg"></span><strong>Large</strong><code>--radius-lg</code></div>
            <div><span class="radius-sample radius-full"></span><strong>Full</strong><code>9999px</code></div>
          </div>
          <p class="source-row"><strong>Source</strong><code>src/styles/globals.css</code></p>
        </div>
      </section>

      <section class="spec" id="components">
        <h2>2. Components</h2>

        <div class="spec-item" id="button">
          <h3>2-1. Button</h3>
          <p class="src">操作を開始する。ラベルには、押したあとに起きることを具体的に書く。</p>
          <div class="demo component-demo">
            <div class="button-row">
              <Button>記事を読む</Button>
              <Button variant="secondary">さらに表示</Button>
              <Button variant="outline">下書きを確認</Button>
              <Button variant="ghost">閉じる</Button>
              <Button variant="link">記事一覧へ</Button>
              <Button variant="destructive">削除する</Button>
            </div>
            <div class="button-row">
              <Button size="sm">Small</Button>
              <Button>Default</Button>
              <Button size="lg">Large</Button>
              <Button disabled>読み込み中…</Button>
            </div>
          </div>
          <details class="code-sample">
            <summary>使用例を表示</summary>
            <div><pre><code>{buttonCode}</code></pre><Button type="button" variant="outline" size="sm" data-copy-button>コピー</Button></div>
          </details>
          <p class="source-row"><strong>Source</strong><code>src/components/ui/button.tsx</code></p>
        </div>

        <div class="spec-item" id="badge">
          <h3>2-2. Badge / Tag</h3>
          <p class="src">Badgeは短い状態、Tagは記事の分類と絞り込みへのリンクを示す。主要な操作や長い説明には使わない。</p>
          <div class="demo component-demo">
            <div class="button-row">
              <Badge>Default</Badge>
              <Badge variant="secondary">Astro</Badge>
              <Badge variant="outline">Design System</Badge>
              <Badge variant="destructive">Error</Badge>
            </div>
            <section class="tag-interaction" data-specification="tag-interaction">
              <div>
                <h4>Tag interaction</h4>
                <p>記事メタ情報のTagは、PostMetaの実装をそのまま使用する。</p>
              </div>
              <div class="tag-interaction-preview">
                <PostMeta date={new Date("2026-07-16")} tags={["Astro", "Design System"]} />
              </div>
              <div class="table-scroll">
                <table class="map">
                  <thead><tr><th>状態</th><th>正規仕様</th></tr></thead>
                  <tbody>
                    <tr><td>Rest</td><td>Secondaryの面と通常の文字色を表示する</td></tr>
                    <tr><td>Hover / Focus</td><td>前景色6%の面を14deg傾け、220ms ease-in-outで左から通す。文字色はLinkへ変える</td></tr>
                    <tr><td>Card coordination</td><td>Tag上では親PostCardの背景色とタイトル色のhoverを重ねない</td></tr>
                    <tr><td>Reduced motion</td><td><code>prefers-reduced-motion: reduce</code>では遷移時間を0sにし、状態変化は維持する</td></tr>
                  </tbody>
                </table>
              </div>
            </section>
          </div>
          <p class="source-row"><strong>Source</strong><code>src/components/ui/badge.tsx</code><code>src/components/PostMeta.astro</code><code>src/components/PostCard.astro</code></p>
        </div>

        <div class="spec-item" id="input">
          <h3>2-3. Input</h3>
          <p class="src">入力の目的はlabelで伝える。Placeholderは入力内容の補助に限定する。</p>
          <div class="demo input-grid">
            <label><span>記事を検索</span><Input placeholder="キーワードを入力" /></label>
            <label><span>無効な入力</span><Input defaultValue="Astro" aria-invalid="true" readOnly /></label>
            <label><span>利用できない入力</span><Input defaultValue="検索を準備しています…" disabled /></label>
          </div>
          <p class="source-row"><strong>Source</strong><code>src/components/ui/input.tsx</code></p>
        </div>

        <div class="spec-item" id="card">
          <h3>2-4. Card</h3>
          <p class="src">関連する情報と操作を1つの単位にまとめる。Header / Content / Footerで構成する。</p>
          <div class="demo card-demo">
            <Card className="specimen-card">
              <CardHeader>
                <CardTitle>Living Design System</CardTitle>
                <CardDescription>実装と同じ部品を確認できる形で並べる。</CardDescription>
                <CardAction><Badge variant="outline">Connected</Badge></CardAction>
              </CardHeader>
              <CardContent><p>カード内ではspacing tokenで情報の関係を表す。</p></CardContent>
              <CardFooter className="border-t"><Button variant="outline" size="sm">詳細を見る</Button></CardFooter>
            </Card>
          </div>
          <p class="source-row"><strong>Source</strong><code>src/components/ui/card.tsx</code></p>
        </div>
      </section>

      <section class="spec" id="patterns">
        <h2>3. Blog patterns</h2>

        <div class="spec-item" id="page-patterns">
          <h3>3-1. PageHero / PostCard</h3>
          <p class="src">ページの目的を伝えたあと、記事タイトル・公開日・タグを一貫した順序で提示する。</p>
          <div class="demo page-demo">
            <PageHero title="Latest Posts" description="最近公開した記事をまとめています。" />
            <div class="post-card-wrap"><PostCard post={specimenPost} /></div>
          </div>
          <p class="source-row"><strong>Source</strong><code>src/components/PageHero.astro</code><code>src/components/PostCard.astro</code></p>
        </div>

        <div class="spec-item">
          <h3>3-2. ページの型</h3>
          <p class="src">ページの目的に合わせて、主要な部品と情報順序を固定する。</p>
          <div class="demo table-scroll">
            <table class="map">
              <thead><tr><th>Page</th><th>目的</th><th>構成</th></tr></thead>
              <tbody>
                <tr><td>Home</td><td>最近の記事と外部知識への入口</td><td>PageHero → Latest Posts → Scrapbox</td></tr>
                <tr><td>Archive / Tag</td><td>記事を時系列・タグで探す</td><td>PageHero → PostCard list</td></tr>
                <tr><td>Post detail</td><td>長文を読む</td><td>記事本文 + Table of Contents + Comments</td></tr>
                <tr><td>Search</td><td>全文・タグで探す</td><td>SearchBox + Tag filter</td></tr>
                <tr><td>Knowledge</td><td>知識の接続を見る</td><td>PageHero + Knowledge Graph</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="spec" id="writing">
        <h2>4. UI writing</h2>

        <div class="spec-item">
          <h3>4-1. 文言設計の原則</h3>
          <p class="src">読者が操作と状態を迷わず理解できるよう、文脈・役割・具体性を基準に書く。</p>
          <div class="demo table-scroll">
            <table class="map">
              <thead><tr><th>原則</th><th>基準</th></tr></thead>
              <tbody>
                <tr><td>文脈から書く</td><td>周囲から明らかな情報は繰り返さない</td></tr>
                <tr><td>役割を分ける</td><td>見出し・説明・操作・状態を混ぜない</td></tr>
                <tr><td>結果を予測できるラベル</td><td>「OK」「実行」ではなく、起きることを書く</td></tr>
                <tr><td>読者が知っている言葉</td><td>内部実装語ではなく画面上の対象を示す</td></tr>
                <tr><td>事実を先に伝える</td><td>確認できない原因を推測しない</td></tr>
                <tr><td>Accessible nameも同時に決める</td><td>表示と読み上げの意味を揃える</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="spec-item">
          <h3>4-2. 状態メッセージ</h3>
          <p class="src">状態は短い見出しと、必要な場合だけ本文または操作を組み合わせる。</p>
          <div class="demo table-scroll">
            <table class="map">
              <thead><tr><th>状態</th><th>見出し・通知</th><th>本文・操作</th></tr></thead>
              <tbody>
                <tr><td>検索中</td><td>検索しています…</td><td>追加説明なし</td></tr>
                <tr><td>検索結果0件</td><td>記事が見つかりません</td><td>キーワードを変えて検索してください。</td></tr>
                <tr><td>検索エラー</td><td>検索できません</td><td>しばらくしてから、もう一度お試しください。</td></tr>
                <tr><td>コピー完了</td><td>コードをコピーしました</td><td><code>aria-live="polite"</code></td></tr>
              </tbody>
            </table>
          </div>
          <p class="source-row"><strong>Specification</strong><code>docs/ui-writing-guidelines.md</code></p>
        </div>
      </section>

      <section class="spec" id="accessibility">
        <h2>5. Accessibility</h2>
        <div class="spec-item">
          <h3>5-1. 操作と読み上げ</h3>
          <div class="demo table-scroll">
            <table class="map">
              <thead><tr><th>対象</th><th>仕様</th></tr></thead>
              <tbody>
                <tr><td>Keyboard</td><td>すべての操作へTabで到達でき、視認可能なfocusを表示する</td></tr>
                <tr><td>Input</td><td>Placeholder以外のAccessible nameを持つ</td></tr>
                <tr><td>Icon button</td><td>操作を表すAccessible nameを持つ</td></tr>
                <tr><td>Theme</td><td>ライト/ダークでsemantic tokenの意味を維持する</td></tr>
                <tr><td>Motion</td><td><code>prefers-reduced-motion</code>で不要な動きを抑制する</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="spec" id="governance">
        <h2>6. Governance</h2>
        <div class="spec-item">
          <h3>6-1. Source of Truth</h3>
          <p class="src">値・構造・原則の正規な置き場所を分け、見本帳はそれらを直接読み込んで確認する。</p>
          <div class="demo table-scroll">
            <table class="map">
              <thead><tr><th>対象</th><th>正規ファイル</th><th>更新時の確認</th></tr></thead>
              <tbody>
                <tr><td>Color / Type / Spacing</td><td><code>src/styles/globals.css</code></td><td>ライト/ダークの標本</td></tr>
                <tr><td>UI components</td><td><code>src/components/ui/</code></td><td>variant・size・状態</td></tr>
                <tr><td>Blog patterns</td><td><code>src/components/</code></td><td>実データに近い標本</td></tr>
                <tr><td>Grid / Writing</td><td><code>docs/</code></td><td>仕様と標本の一致</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="spec-item">
          <h3>6-2. 更新方法</h3>
          <ol class="rule-list">
            <li>変更対象のSource of Truthを更新する。</li>
            <li>この見本帳の標本または説明を更新する。</li>
            <li><code>pnpm test:design-system</code>で実装との接続を確認する。</li>
            <li><code>pnpm build</code>で本番成果物にページが含まれないことを確認する。</li>
          </ol>
        </div>
      </section>

      <footer class="book-footer">
        <span>KJR020 Living Design System</span>
        <a href="#overview">ページ上部へ</a>
      </footer>
    </main>

    <p class="copy-status" aria-live="polite"></p>

    <script>
      const updateTokenValues = () => {
        const styles = getComputedStyle(document.documentElement);
        document.querySelectorAll<HTMLElement>("[data-token-value]").forEach((element) => {
          const token = element.dataset.tokenValue;
          if (token) element.textContent = styles.getPropertyValue(token).trim();
        });
      };
      updateTokenValues();
      new MutationObserver(updateTokenValues).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["class"],
      });

      const copyStatus = document.querySelector<HTMLElement>(".copy-status");
      document.querySelectorAll<HTMLButtonElement>("[data-copy-button]").forEach((button) => {
        button.addEventListener("click", async () => {
          const code = button.closest(".code-sample")?.querySelector("code")?.textContent;
          if (!code) return;
          await navigator.clipboard.writeText(code);
          if (copyStatus) copyStatus.textContent = "コードをコピーしました";
          button.textContent = "コピーしました";
          window.setTimeout(() => {
            button.textContent = "コピー";
            if (copyStatus) copyStatus.textContent = "";
          }, 1600);
        });
      });
    </script>
  </body>
</html>
