---
import DesignSystemLayout from "../components/DesignSystemLayout.astro";
import { designSystemPages, legacySectionRoutes } from "../navigation";

const categoryPages = designSystemPages.filter((page) => page.id !== "overview");
---

<DesignSystemLayout
  activePage="overview"
  title="KJR020's Blog デザインシステム"
  description="KJR020's Blogの実装と接続されたデザインシステム"
>
  <header class="book-intro" id="overview">
    <h1 class="book-title">KJR020's Blog<br />デザインシステム</h1>
    <p class="book-lead">
      KJR020's Blogの視覚言語、部品、状態、ページ構造、UIライティングを定義する正規仕様。
      標本はブログと同じトークンとコンポーネントから描画する。
    </p>
    <div class="scope-note">
      <strong>適用範囲</strong>
      <span>
        ブログのすべてのページと部品に適用する。
      </span>
    </div>
  </header>

  <section class="spec" id="categories">
    <h2>カテゴリ</h2>
    <nav aria-label="デザインシステムのカテゴリ">
      <ul class="design-system-directory">
        {categoryPages.map((page) => (
          <li>
            <a class="spec-page-link" href={page.href}>
              <strong>{page.label}</strong>
              <span>{page.description}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </section>

  <script is:inline define:vars={{ legacySectionRoutes }}>
    const section = window.location.hash.slice(1);
    const destination = legacySectionRoutes[section];

    if (destination) {
      window.location.replace(`${destination}#${section}`);
    }
  </script>
</DesignSystemLayout>
