---
const colorTokens = [
  { name: "--background", label: "Background / Card", role: "ページと面" },
  { name: "--foreground", label: "Foreground", role: "本文と主要情報" },
  { name: "--primary", label: "Primary", role: "主要操作" },
  { name: "--link", label: "Link", role: "遷移可能な情報" },
  { name: "--secondary", label: "Secondary / Muted", role: "補助操作と弱い面" },
  { name: "--muted-foreground", label: "Muted foreground", role: "補助情報" },
  { name: "--border", label: "Border / Input", role: "領域の境界" },
  { name: "--destructive", label: "Destructive", role: "破壊的な操作とエラー" },
] as const;

const calloutTokens = [
  ["--callout-note", "Note", "追加の背景情報や参照"],
  ["--callout-tip", "Tip", "実装を進めるためのヒント"],
  ["--callout-warning", "Warning", "注意が必要な条件"],
  ["--callout-danger", "Danger", "破壊的・危険な操作"],
] as const;

const typeScale = [
  ["Display", "--font-size-display", "700", "404など単一状態の強調"],
  ["Title 1", "--font-size-title1", "700", "ページタイトル・記事タイトル"],
  ["Title 2", "--font-size-title2", "700", "セクション見出し"],
  ["Title 3", "--font-size-title3", "500", "小見出し"],
  ["Body", "--font-size-body", "400", "本文"],
  ["Small", "--font-size-small", "400", "補助テキスト・メタ情報"],
  ["Caption", "--font-size-caption", "400", "短い補足"],
] as const;

const spacingTokens = [
  ["φ⁻³", "--phi-neg3"],
  ["φ⁻²", "--phi-neg2"],
  ["φ⁻¹", "--phi-neg1"],
  ["φ⁰", "--phi-0"],
  ["φ¹", "--phi-1"],
  ["φ²", "--phi-2"],
  ["φ³", "--phi-3"],
  ["φ⁴", "--phi-4"],
] as const;

type FoundationSection = "tokens" | "layout" | "states";

interface Props {
  sections?: readonly FoundationSection[];
}

const { sections = ["tokens", "layout", "states"] } = Astro.props;
const shows = (section: FoundationSection) => sections.includes(section);
---

{shows("tokens") && (
<section class="spec" id="tokens">
  <h2>1. トークン</h2>

  <div class="spec-item" id="color">
    <h3>1-1. 色の役割</h3>
    <p class="src">
      ライト/ダークの2テーマ。ニュートラルを面と文字に使い、青をリンク、赤を破壊的状態、4色を記事内コールアウトに限定する。色名ではなく用途を表すsemantic tokenを選ぶ。
    </p>
    <div class="demo swatches">
      {colorTokens.map((token) => (
        <div class="swatch" data-token={token.name}>
          <div class="swatch-color" style={`--swatch: var(${token.name})`}></div>
          <strong>{token.label}</strong>
          <code data-token-value={token.name}>var({token.name})</code>
          <span>{token.role}</span>
        </div>
      ))}
    </div>
    <p class="source-row"><strong>Source</strong><code>src/styles/globals.css</code></p>
  </div>

  <div class="spec-item" id="callout-colors">
    <h3>1-2. 記事コールアウト色</h3>
    <p class="src">記事本文の補足種別にだけ使用する。面を塗らず、左2pxの境界とタイトル文字で識別する。</p>
    <div class="demo swatches">
      {calloutTokens.map(([token, label, role]) => (
        <div class="swatch" data-token={token}>
          <div class="swatch-color" style={`--swatch: var(${token})`}></div>
          <strong>{label}</strong>
          <code data-token-value={token}>var({token})</code>
          <span>{role}</span>
        </div>
      ))}
    </div>
    <p class="source-row"><strong>Source</strong><code>src/styles/globals.css</code></p>
  </div>

  <div class="spec-item" id="typography">
    <h3>1-3. 文字階層</h3>
    <p class="src">ヘッダーはsystem sans、本文と見出しはNoto Sans JP、コードとトークン名はJetBrains Monoを使用する。サイズと行高は黄金比φを中心に組む。</p>
    <div class="demo type-list">
      {typeScale.map(([label, token, weight, usage]) => (
        <div class="type-row">
          <div style={`font-size: var(${token}); font-weight: ${weight}`}>読みやすさから設計する</div>
          <dl>
            <div><dt>{label}</dt><dd><code>{token}</code></dd></div>
            <div><dt>用途</dt><dd>{usage}</dd></div>
          </dl>
        </div>
      ))}
    </div>
    <p class="source-row"><strong>Source</strong><code>src/styles/globals.css</code><code>src/layouts/BaseHead.astro</code></p>
  </div>

  <div class="spec-item" id="spacing">
    <h3>1-4. 黄金比スペーシング</h3>
    <p class="src">関連性が強い要素には狭い値を使い、セクションなど関係が切り替わる場所には広い値を使う。</p>
    <div class="demo spacing-list">
      {spacingTokens.map(([label, token]) => (
        <div class="spacing-row">
          <code>{label}</code>
          <span class="spacing-bar" style={`--space: var(${token})`}></span>
          <code>{token}</code>
          <span data-token-value={token}>var({token})</span>
        </div>
      ))}
    </div>
    <p class="source-row"><strong>Source</strong><code>src/styles/globals.css</code></p>
  </div>

  <div class="spec-item" id="radius">
    <h3>1-5. 角丸・影</h3>
    <p class="src">基準角丸は0.618rem。情報のまとまりを示す目的で使用し、装飾として過剰に丸めない。Cardには控えめなshadowを使う。</p>
    <div class="demo foundation-pair">
      <div class="radius-grid">
        <div><span class="radius-sample radius-sm"></span><strong>Small</strong><code>--radius-sm</code></div>
        <div><span class="radius-sample radius-md"></span><strong>Medium</strong><code>--radius-md</code></div>
        <div><span class="radius-sample radius-lg"></span><strong>Large</strong><code>--radius-lg</code></div>
        <div><span class="radius-sample radius-full"></span><strong>Full</strong><code>9999px</code></div>
      </div>
      <div class="shadow-specimen">
        <span aria-hidden="true"></span>
        <div><strong>Card shadow</strong><code>--shadow-card</code><small>境界を補助する最小限の奥行き</small></div>
      </div>
    </div>
    <p class="source-row"><strong>Source</strong><code>src/styles/globals.css</code><code>src/design-system/styles.css</code></p>
  </div>
</section>
)}

{shows("layout") && (
<section class="spec" id="layout">
  <h2>2. レイアウト原則</h2>

  <div class="spec-item" id="page-shell">
    <h3>2-1. ページシェル</h3>
    <p class="src">全ページはSticky Header → Main → Footerで構成する。Mainの栗マスコットは本文操作を妨げない背景要素として扱う。</p>
    <div class="demo layout-stack">
      <div class="layout-bar"><strong>Sticky Header</strong><span>border-bottom · backdrop blur</span></div>
      <div class="layout-bar layout-main"><strong>Main</strong><span>flex: 1 · Kuri watermark</span></div>
      <div class="layout-bar"><strong>Footer</strong><span>border-top · privacy / social links</span></div>
    </div>
    <p class="source-row"><strong>Source</strong><code>src/layouts/BaseLayout.astro</code></p>
  </div>

  <div class="spec-item" id="grid">
    <h3>2-2. Gridの基本構造</h3>
    <p class="src">ページの骨格をColumns / Gutters / Marginsで定義する。Gridへ揃えるのはトップレベルのコンテナで、部品内部はspacing tokenで配置する。</p>
    <div class="demo">
      <div class="grid-anatomy" aria-label="12列グリッドの見本">
        {Array.from({ length: 12 }).map((_, index) => <span>{index + 1}</span>)}
      </div>
      <div class="grid-legend" aria-hidden="true">
        <span><i class="grid-key grid-key-column"></i>Column</span>
        <span><i class="grid-key grid-key-gutter"></i>Gutter</span>
        <span><i class="grid-key grid-key-margin"></i>Margin</span>
      </div>
    </div>
    <p class="source-row"><strong>Specification</strong><code>docs/grid-system.md</code></p>
  </div>

  <div class="spec-item" id="grid-breakpoints">
    <h3>2-3. Grid breakpoints</h3>
    <p class="src">2 / 6 / 12 columnsを、ブログの基準である768pxと1024pxへ合わせる。Breakpointはviewport全体の幅で判定する。</p>
    <div class="demo table-scroll">
      <table class="map">
        <thead><tr><th>Mode</th><th>Viewport</th><th>Columns</th><th>Gutter</th><th>Margin</th></tr></thead>
        <tbody>
          <tr><td>Compact</td><td>320–767px</td><td>2</td><td>12px</td><td>16px</td></tr>
          <tr><td>Medium</td><td>768–1023px</td><td>6</td><td>12px</td><td>16px</td></tr>
          <tr><td>Wide</td><td>1024px以上</td><td>12</td><td>16px</td><td>32px</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="spec-item" id="grid-types">
    <h3>2-4. Grid types</h3>
    <p class="src">長文を無制限に広げない。構造化ページはFixed-wide、読むことが中心のページはFixed-narrow、横方向の広がりに意味がある領域だけFluidを使う。</p>
    <div class="demo table-scroll">
      <table class="map">
        <thead><tr><th>Type</th><th>最大幅</th><th>用途</th></tr></thead>
        <tbody>
          <tr><td>Fixed-wide</td><td>1152px / 72rem</td><td>記事＋目次、検索＋タグ</td></tr>
          <tr><td>Fixed-narrow</td><td>864px / 54rem</td><td>記事単体、Privacy、長文の説明</td></tr>
          <tr><td>Fluid</td><td>制限なし</td><td>横scroll領域の内部に限定</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="spec-item" id="grid-composition">
    <h3>2-5. 配置パターン</h3>
    <p class="src">Wideでは本文を9 columns、補助領域を3 columnsに置く。Medium以下はDOM順を保ったまま全幅で縦積みし、目次は折りたたみ表示へ切り替える。</p>
    <div class="demo grid-composition">
      <div class="grid-region grid-region-header"><strong>Page header</strong><span>2 / 6 / 12 columns</span></div>
      <div class="grid-region grid-region-main"><strong>Article / Search results</strong><span>Wide: 9 / 12 columns</span></div>
      <div class="grid-region grid-region-aside"><strong>TOC / Filters</strong><span>Wide: 3 / 12 columns</span></div>
    </div>
  </div>

  <div class="spec-item" id="width-tokens">
    <h3>2-6. 幅トークン</h3>
    <p class="src">最大幅は用途名で定義する。長文にはFixed-narrow、本文と補助領域を並べるページにはFixed-wide、overlayには専用幅を使う。</p>
    <div class="demo layout-stack width-stack">
      <div class="layout-bar width-wide"><strong>--grid-wide</strong><span>1152px · 本文＋補助領域</span></div>
      <div class="layout-bar width-narrow"><strong>--grid-narrow</strong><span>864px · 長文</span></div>
      <div class="layout-bar width-overlay"><strong>--overlay-lg</strong><span>512px · Page Gridの対象外</span></div>
    </div>
  </div>

  <div class="spec-item" id="spacing-hierarchy">
    <h3>2-7. 余白の階層</h3>
    <p class="src">情報の関係が強いほど狭く、セクションやページの境界ほど広い余白を使う。</p>
    <div class="demo table-scroll">
      <table class="map">
        <thead><tr><th>関係</th><th>主な値</th><th>実装例</th></tr></thead>
        <tbody>
          <tr><td>同一要素内</td><td>φ⁻³〜φ⁻¹</td><td>ナビ間隔、タイトルと補足、カード行間</td></tr>
          <tr><td>関連要素間</td><td>φ⁰〜φ¹</td><td>カードpadding、見出しと一覧</td></tr>
          <tr><td>セクション間</td><td>φ¹〜φ²</td><td>Latest Posts / Scrapbox、記事header</td></tr>
          <tr><td>ページ外周</td><td>px-4 + py-φ²</td><td>一覧・記事詳細・ヒーロー</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="spec-item" id="emphasis-hierarchy">
    <h3>2-8. 見出しと強調の階層</h3>
    <p class="src">ページタイトル → セクション見出し → カードタイトル → メタ情報の順に、サイズ・太さ・色を弱める。</p>
    <div class="demo emphasis-demo">
      <div class="emphasis-level emphasis-page"><strong>Page title</strong><span>title1 / bold / tracking-tight</span></div>
      <div class="emphasis-level emphasis-section"><strong>Section heading</strong><span>title3 / 左にlink色2px線</span></div>
      <div class="emphasis-level"><strong>Item title</strong><span>body / semibold / hoverでlink色</span></div>
      <div class="emphasis-level"><strong>Metadata</strong><span>small / muted foreground</span></div>
    </div>
  </div>
</section>
)}

{shows("states") && (
<section class="spec" id="states">
  <h2>3. 状態の体系</h2>

  <div class="spec-item" id="interaction-states">
    <h3>3-1. 操作状態</h3>
    <p class="src">色の反転だけに頼らず、背景・文字色・ring・opacityの組み合わせで表す。</p>
    <div class="demo state-grid">
      <div class="interactive-state">Default<span>surface + border</span></div>
      <div class="interactive-state state-hover">Hover<span>accent background</span></div>
      <div class="interactive-state state-focus">Focus visible<span>visible ring</span></div>
      <div class="interactive-state state-disabled">Disabled<span>opacity 50%</span></div>
      <div class="interactive-state state-invalid">Invalid<span>destructive border / ring</span></div>
    </div>
  </div>

  <div class="spec-item" id="async-states">
    <h3>3-2. 非同期データの4状態</h3>
    <p class="src">非同期コンテンツは、ローディング・表示済み・空・エラーを区別する。回復可能なエラーには再読み込みを用意する。</p>
    <div class="demo state-grid async-grid">
      <div class="async-state"><span class="spinner" aria-hidden="true"></span><strong>読み込んでいます…</strong></div>
      <div class="async-state"><span aria-hidden="true">✓</span><strong>コンテンツを表示</strong></div>
      <div class="async-state"><span aria-hidden="true">◇</span><strong>ページがありません</strong></div>
      <div class="async-state"><span aria-hidden="true">!</span><strong>読み込めませんでした</strong><small>再読み込み</small></div>
    </div>
  </div>

  <div class="spec-item" id="selection-states">
    <h3>3-3. 現在地と選択</h3>
    <p class="src">Headerとサイドバーの現在ページはlink色＋semibold。見出しのアクセントラインは現在地表示へ転用しない。目次は現在見出しをforeground＋medium。Command Paletteは選択行をaccent面で示す。</p>
    <div class="demo selection-demo">
      <a href="#selection-states" aria-current="page">Page navigation current</a>
      <a href="#selection-states" aria-current="location">TOC current</a>
      <div role="option" aria-selected="true">Command Palette selected</div>
    </div>
  </div>
</section>
)}
